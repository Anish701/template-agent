# Base image for AgentForge agents - config loaded from volume mount
#
# Expected volume mount:
#   - /app/config/agent/ (ConfigMap or PVC)
#   - Must contain: PROMPT.md, mcp.json, skills/, subagents/
#
# Build: podman build -f Containerfile.base -t ai-template-agent:v1.0.0 .
# Run:   podman run -v /path/to/config:/app/config/agent:ro ai-template-agent:v1.0.0

ARG PYTHON_TAG=3.14.4-builder
FROM registry.access.redhat.com/hi/python:${PYTHON_TAG}

WORKDIR /app
USER root

# Copy only dependencies manifest (not application code yet)
COPY pyproject.toml /app/pyproject.toml

# Install dependencies - this layer is shared across ALL agents
RUN pip install --no-cache-dir uv && \
    uv venv /app/.venv && \
    uv pip install --python /app/.venv/bin/python -r pyproject.toml && \
    mkdir -p /app/.cache && chown -R 65532:root /app/.cache

# Switch to non-root user for application files
USER 65532

# Copy application code (NOT config/ directory - that's mounted at runtime)
COPY --chown=65532:root deep_agent /app/deep_agent
COPY --chown=65532:root aegra.json /app/aegra.json
COPY --chown=65532:root runtime /app/runtime

# Environment variables (same as current)
ENV PYTHONPATH=/app
ENV AGENT_HOST=0.0.0.0
ENV AGENT_PORT=5002
ENV AEGRA_CONFIG=/app/aegra.json

# Config will be mounted here at runtime from ConfigMap/PVC
# Override CONFIG_PATH in deployment.yaml if using a custom mount location
ENV CONFIG_PATH=/app/config/agent

EXPOSE 5002

# Use config loader entrypoint that validates mount before starting uvicorn
CMD ["/bin/sh", "-c", "exec /app/.venv/bin/python -m runtime.config_loader"]
