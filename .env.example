# Agent Server Configuration
AGENT_HOST=0.0.0.0
AGENT_PORT=5002

# Optional: SSL/TLS configuration (comment out if not using HTTPS)
AGENT_SSL_KEYFILE=/path_to/ssl_key.pem
AGENT_SSL_CERTFILE=/path_to/ssl_cert.pem

# Python Logging
PYTHON_LOG_LEVEL=INFO

# pgvector credentials for agentic memory
POSTGRES_USER=pgvector
POSTGRES_PASSWORD=pgvector
POSTGRES_HOST=0.0.0.0
POSTGRES_PORT=5432
POSTGRES_DB=pgvector

# Langfuse Configuration (4.x)
LANGFUSE_SECRET_KEY=langfuse-secret-key
LANGFUSE_PUBLIC_KEY=langfus-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Langfuse 4.x uses LANGFUSE_TRACING_ENVIRONMENT env var (auto-read by client and handler)
LANGFUSE_TRACING_ENVIRONMENT=development

#Google Vertex AI service creds
GOOGLE_APPLICATION_CREDENTIALS_CONTENT='{
    "type": "service_account",
    "project_id": "data-and-ai-gemini",
    ...
    ...
    ...
    "universe_domain": "googleapis.com"
  }'
